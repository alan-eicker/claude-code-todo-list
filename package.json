    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.10.1",
    "prettier": "^3.3.3",
    "style-loader": "^4.0.0",
